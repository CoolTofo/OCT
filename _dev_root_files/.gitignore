# Python caches
__pycache__/
*.pyc
*.pyo
*$py.class

# Virtual environments
.venv/
venv/
env/

# Local secrets
.env
**/.env
**/API/.env
*.key

# Runtime data generated by the app
**/history.json
**/global_config.json
**/data/conversations/*
**/data/canvases/*
**/assets/input/*
**/assets/output/*
**/assets/preview/*
**/output/*
**/data/comfyui_exports/*
*.log

# Bundled runtimes and release artifacts
dist/
*.zip
**/python/
**/python.zip
**/packages/

# Keep placeholder files in otherwise ignored runtime folders
!**/assets/input/
!**/assets/input/.gitkeep
!**/assets/output/
!**/assets/output/.gitkeep
!**/assets/library/
!**/assets/library/.gitkeep
!**/data/canvases/
!**/data/canvases/.gitkeep
!**/data/conversations/
!**/data/conversations/.gitkeep
!**/output/
!**/output/.gitkeep

# Nested Git metadata
**/.git/
**/.svn/
.git-backups/

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Codex/work notes
**/.workbuddy/
